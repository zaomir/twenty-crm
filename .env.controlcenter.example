# Copy to .env next to docker-compose.yml (do not commit .env)
# openssl rand -hex 32   → APP_SECRET

SERVER_URL=https://controlcenter.me

POSTGRES_DB=controlcenter_prod
POSTGRES_USER=controlcenter_user
POSTGRES_PASSWORD=change_me_strong_password

# Host port mappings (optional overrides)
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6381

# Required — Twenty server bootstrap fails without this
APP_SECRET=change_me_generate_with_openssl_rand_hex_32
